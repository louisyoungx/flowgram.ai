{
    "extends": "@flowgram.ai/ts-config/tsconfig.flow.path.json",
    "compilerOptions": {
        "target": "ES2017",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
        "plugins": [],
        "baseUrl": "src",
        "paths": {
            "@api/*": ["api/*"],
            "@server/*": ["server/*"],
            "@config/*": ["config/*"],
            "@runtime/*": ["runtime/*"]
        }
    },
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": ["node_modules"]
}
